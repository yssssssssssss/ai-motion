{
  "version": "1.0",
  "id": "jd-horizontal-switch",
  "name": "横向切换代码动效",
  "sourceKind": "builtin-component",
  "runtime": { "engine": "html", "entry": "source/index.html", "sandbox": "iframe" },
  "capabilities": ["builtin", "editable", "export-html"],
  "motionRecipes": [
    {
      "recipeId": "horizontal-switch.tab-navigation",
      "recipeName": "横向切换 / Tab导航",
      "category": "transition",
      "targetLayerIds": ["tabNavigation"],
      "targetSelectors": [".tab-nav"],
      "paramIds": ["tabGap", "indicatorWidth", "easing"],
      "trigger": "click",
      "source": "builtin",
      "confidence": 1
    },
    {
      "recipeId": "horizontal-switch.channel-tab",
      "recipeName": "横向切换 / 频道Tab",
      "category": "transition",
      "targetLayerIds": ["channelTabs"],
      "targetSelectors": [".channel-tabs"],
      "paramIds": [
        "channelMotionDuration",
        "easing",
        "channelTabLabel1",
        "channelTabLabel2",
        "channelTabLabel3",
        "channelTabLabel4",
        "channelTabLabel5",
        "channelTabLabel6",
        "channelTabLabelBg"
      ],
      "trigger": "click",
      "source": "builtin",
      "confidence": 1
    },
    {
      "recipeId": "horizontal-switch.tabbar",
      "recipeName": "横向切换 / Tabbar底导",
      "category": "transition",
      "targetLayerIds": ["bottomTabbar"],
      "targetSelectors": [".bottom-tabbar"],
      "paramIds": [
        "bottomTabbarMotionDuration",
        "bottomTabbarMotionEasing",
        "bottomTabbarSizeEasing",
        "bottomTabbarActiveColor",
        "bottomTabbarActiveBg",
        "bottomTabbarLabel1",
        "bottomTabbarLabel2",
        "bottomTabbarLabel3",
        "bottomTabbarLabel4",
        "bottomTabbarLabel5"
      ],
      "trigger": "click",
      "source": "builtin",
      "confidence": 1
    }
  ],
  "params": [
    {
      "id": "tabGap",
      "label": "Tab 间距",
      "type": "range",
      "default": 336,
      "constraints": { "min": 160, "max": 480, "step": 1, "unit": "px" },
      "status": "confirmed",
      "targets": [
        {
          "kind": "css-variable",
          "file": "source/style.css",
          "selector": ":root",
          "name": "--tab-gap"
        }
      ]
    },
    {
      "id": "tabStartX",
      "label": "首个 Tab X",
      "type": "range",
      "default": 398,
      "constraints": { "min": 0, "max": 1118, "step": 1, "unit": "px" },
      "status": "confirmed",
