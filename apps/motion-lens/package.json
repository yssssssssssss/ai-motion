{
  "name": "@motion-lens/app",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5176",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "vite build && vite build --ssr src/server/startProductionServer.ts --outDir dist-server",
    "start": "node dist-server/startProductionServer.js"
  },
  "dependencies": {
    "@motion-lens/core": "workspace:*",
    "@motion-knowledge/base": "workspace:*",
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
